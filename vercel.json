{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "functions": {
        "kanban/wsgi.py": {
            "excludeFiles": "{tests/**,__tests__/**,**/*.test.py,**/test_*.py,fixtures/**,__fixtures__/**,testdata/**,sample-data/**,static/**,assets/**}"
        }
    },
    "rewrites": [
        {
            "source": "/static/(.*)",
            "destination": "/static/$1"
        },
        {
            "source": "/(.*)",
            "destination": "kanban/wsgi.py"
        }
    ]
}
